{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "paths": {
      "@/*": ["./*"],
      "@worker/*": ["../worker/*"]
    },
    "composite": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.vue", "../test/client/**/*.ts"],
  "references": [{ "path": "../worker" }]
}
