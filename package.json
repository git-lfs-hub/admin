{
  "name": "@git-lfs-hub/admin",
  "private": true,
  "type": "module",
  "scripts": {
    "config:vars": "git-lfs-hub-config vars . --env dev",
    "config": "git-lfs-hub-config worker .",
    "types": "wrangler types --env-interface CloudflareBindings",
    "compile": "tsgo -b",
    "lint": "oxlint .",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "test:e2e": "bun run playwright test",
    "test-coverage": "bun run test -- --coverage",
    "dev": "bun run vite",
    "build": "bun run vite build",
    "preview": "bun run build && vite preview",
    "deploy": "bun run build && wrangler deploy",
    "vitest": "bun run compile && bun run lint && vitest",
    "playwright": "bun run compile && bun run lint && playwright",
    "vite": "bun run compile && bun run lint && vite"
  },
  "dependencies": {
    "@git-lfs-hub/lib": "file:../lib",
    "@octokit/rest": "^22.0.1",
    "@tanstack/vue-query": "^5.100.14",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "drizzle-orm": "^0.45.2",
    "filesize": "^11.0.17",
    "hono": "^4.12.23",
    "vue": "^3.5.35",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@git-lfs-hub/config": "file:../config",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vue/test-utils": "^2.4.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "happy-dom": "^20.9.0",
    "lucide-vue-next": "^1.0.0",
    "oxlint": "^1.67.0",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-sonner": "^2.0.9",
    "wrangler": "^4.17.0"
  },
  "overrides": {
    "vite": "8.0.14"
  },
  "engines": {
    "node": "^26.1.0"
  },
  "packageManager": "bun@1.3.13"
}
