{
  "name": "@git-lfs-hub/admin",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "scripts/init-test.sh && vite",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "deploy": "bun run build && wrangler deploy",
    "test": "scripts/init-test.sh && vitest run",
    "test:watch": "scripts/init-test.sh && vitest",
    "types": "wrangler types --env-interface CloudflareBindings"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@git-lfs-hub/auth": "file:../auth",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@vitest/coverage-istanbul": "^4.1.0",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.6.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.17.0"
  }
}
